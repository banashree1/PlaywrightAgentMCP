{
  "name": "jira-mcp-server",
  "version": "1.0.0",
  "description": "JIRA MCP Server for BanaMCPAgentsAutomobile workspace",
  "type": "module",
  "main": "jira-mcp-server.mjs",
  "scripts": {
    "start": "node jira-mcp-server.mjs",
    "dev": "node --inspect jira-mcp-server.mjs",
    "setup": "node setup-jira-workspace.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0"
  },
  "keywords": [
    "mcp",
    "jira",
    "automation",
    "testing",
    "playwright"
  ],
  "repository": {
    "type": "git",
    "url": "local"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "mcp": {
    "name": "jira-automation",
    "description": "JIRA integration for MCP Agents automobile insurance testing",
    "workspace": "BanaMCPAgentsAutomobile",
    "capabilities": [
      "issue-management",
      "test-linking", 
      "automation-tracking",
      "sprint-planning"
    ]
  }
}